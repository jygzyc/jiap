{
  "name": "jiap-cli",
  "version": "2.2.3",
  "description": "JIAP CLI - Java Intelligence Analysis Platform (TypeScript)",
  "type": "module",
  "bin": {
    "jiap": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node scripts/build.mjs",
    "dev": "node --import tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "android",
    "security",
    "analysis",
    "jadx",
    "decompiler",
    "cli",
    "jiap"
  ],
  "author": "Yves",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jygzyc/jiap"
  },
  "bugs": {
    "url": "https://github.com/jygzyc/jiap/issues"
  },
  "homepage": "https://github.com/jygzyc/jiap#readme"
}
