#!/usr/bin/env bash
# SessionStart hook for DECX plugin

set -euo pipefail

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

session_context=$(cat <<'EOF'
<EXTREMELY_IMPORTANT>
You have DECX skills installed.

Use `using-decx` first for any DECX-related task.
Route to `decxcli`, `decxcli-app-vulnhunt`, `decxcli-framework-vulnhunt`, or `decxcli-poc` as needed.
If the work can be split, use `decx-subagent-analysis`.

DECX rules:
- Session-backed `decx code` and `decx ard` commands need `-P <port>`
- `decx ard system-services` and `decx ard perm-info` are adb-backed and use `--serial` / `--adb-path`
- If a command is missing, rejected, or unclear, run the nearest `--help` first
- Keep one DECX session per target
- Keep artifacts under `.decx-analysis/<target-name>/`
- Close the DECX session only when the workflow is complete
</EXTREMELY_IMPORTANT>
EOF
)

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
session_context_escaped=$(escape_for_json "$session_context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context_escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context_escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context_escaped"
fi

exit 0
